# NextLayerSec Guides — .gitignore
#
# Repo is markdown + Python + GitHub Actions YAML. This file blocks the
# common detritus that those generate locally.

# --- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual envs
.venv/
venv/
env/
ENV/

# --- Node / npm (created by `npx markdownlint-cli2`) ------------------------
node_modules/
package-lock.json
.npm/

# --- Editors / OS -----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Local environment + secrets --------------------------------------------
.env
.env.*
*.local
*.secret

# --- Logs / temp ------------------------------------------------------------
*.log
*.tmp
*.bak
tmp/
temp/

# --- CI artifacts -----------------------------------------------------------
zizmor.sarif
results.sarif
*.sarif.gz

# --- Build / packaging ------------------------------------------------------
dist/
build/

# --- File types we want to ignore by extension (per maintainer request) ----
*.seo
*.ot
*.OT
